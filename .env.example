# ─────────────────────────────────────────────────────────────────────────────
# QuantML environment template.  Copy to `.env` and fill in.
#   cp .env.example .env
# Frontend reads NEXT_PUBLIC_* at build time (also put these in frontend/.env.local).
# Backend reads the rest at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend ────────────────────────────────────────────────────────────────
# Point the web app at the FastAPI backend. Leave empty to use the built-in
# Next.js mock route handlers instead.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Backend core ────────────────────────────────────────────────────────────
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins allowed to call the API from the browser.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Market data provider (pick one — fill the matching key) ─────────────────
# Free/affordable options: Alpaca, Polygon, Tiingo, Alpha Vantage, Finnhub, yfinance (no key).
MARKET_DATA_PROVIDER=yfinance
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_FEED=iex
POLYGON_API_KEY=
TIINGO_API_KEY=
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=

# ── Database / storage ──────────────────────────────────────────────────────
# Local dev defaults to DuckDB/SQLite files under data/. Swap to Postgres for prod.
DATABASE_URL=sqlite:///./data/quantml.db
# DATABASE_URL=postgresql+psycopg://quant:quant@localhost:5432/quantml

# ── ML / experiment tracking ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MODEL_REGISTRY_DIR=./data/models
DEFAULT_MODEL=XGBoost-v3
UNIVERSE=NASDAQ100

# ── RAG research assistant (LLM + vector store) ─────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTORSTORE_DIR=./data/vectorstore

# ── Execution architecture ──────────────────────────────────────────────────
# The ML model ONLY generates signals. A Portfolio/Risk layer turns signals into
# proposed orders. Only the Execution Adapter below can act on them.
#
#   EXECUTION_MODE:        backtest = simulated fills (implemented)
#                          paper    = Alpaca paper account (stub for now)
#                          live     = real orders (disabled by design)
#   BROKER_PROVIDER:       none | alpaca
#   LIVE_TRADING_ENABLED:  hard safety gate — must be true for live to run
EXECUTION_MODE=backtest
BROKER_PROVIDER=none
LIVE_TRADING_ENABLED=false

# paper | live  — kept on paper until thoroughly validated.
TRADING_MODE=paper
