# Research assistant (/api/research) — server-side only, never exposed to the browser.
# Without a key the endpoint returns the built-in sample answer, so the app still runs.
# Copy to .env.local for local dev, or set it as an env var in your host (e.g. Vercel).
ANTHROPIC_API_KEY=

# Optional: point the frontend at the FastAPI backend instead of the built-in /api routes.
# NEXT_PUBLIC_API_URL=http://localhost:8000
